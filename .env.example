# === Supabase (required for production) ===
# Get these from https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for in-app account deletion via /api/account (server-only, never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: for Capacitor native builds that should point to deployed HTTPS app URL
CAPACITOR_SERVER_URL=https://your-production-domain.com

# === OpenAI (optional – for real AI photo verification) ===
# Without this, the app uses demo mode with simulated verification.
OPENAI_API_KEY=sk-...

# === Custom AI: proof photo *suggestions* (optional – before creating a goal) ===
# This is separate from CUSTOM_AI_VERIFY_URL. Without one of the URLs below, the app shows placeholder prompts.
# POST JSON { "title", "goalTitle" } (same string) → JSON with 2–3 strings in suggestions[], prompts[], ideas[],
# nested data/result, or a top-level string[]. See CUSTOM_AI.md.
# CUSTOM_AI_SUGGESTIONS_URL=https://your-api.com/goal-proof-suggestions
# Aliases (first non-empty wins): CUSTOM_AI_GOAL_SUGGESTIONS_URL, AI_PROOF_SUGGESTIONS_URL
# CUSTOM_AI_SUGGESTIONS_API_KEY=optional-bearer-token

# === Resend (password reset + email confirmation) ===
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_...
# REQUIRED in production: set on Vercel (or host) as RESEND_FROM_EMAIL — a sender on your verified Resend domain.
# Without it, Resend only allows onboarding@resend.dev, which delivers to your own account email, not users.
# Example: Proveit <noreply@yourdomain.com>
RESEND_FROM_EMAIL=Proveit <noreply@yourdomain.com>

# === Stripe (optional – for paid plans) ===
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
