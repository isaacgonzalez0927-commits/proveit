# === Supabase (required for production) ===
# Get these from https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for in-app account deletion via /api/account (server-only, never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: for Capacitor native builds that should point to deployed HTTPS app URL
CAPACITOR_SERVER_URL=https://your-production-domain.com

# === OpenAI (optional – photo verification + “Get AI photo ideas” on goals) ===
# With OPENAI_API_KEY set: proof photos can use GPT-4o vision (see /api/verify), and goal photo ideas use gpt-4o-mini
# automatically — no CUSTOM_AI_SUGGESTIONS_URL required unless you want your own suggestion API.
OPENAI_API_KEY=sk-...

# === Custom AI: proof photo *suggestions* (optional – before creating a goal) ===
# Separate from CUSTOM_AI_VERIFY_URL (photo check). Set the full URL to YOUR suggestions endpoint here.
# POST JSON { "title", "goalTitle" } (same string) → JSON with 2–3 strings in suggestions[], prompts[], ideas[],
# nested data/result, or a top-level string[]. See CUSTOM_AI.md.
# CUSTOM_AI_SUGGESTIONS_URL=https://your-api.com/goal-proof-suggestions
# Aliases (first non-empty wins): CUSTOM_AI_GOAL_SUGGESTIONS_URL, AI_PROOF_SUGGESTIONS_URL, CUSTOM_AI_SUGGESTION_URL (typo)
# CUSTOM_AI_SUGGESTIONS_API_KEY=optional-bearer-token

# === Resend (password reset + email confirmation) ===
# API key: https://resend.com/api-keys
RESEND_API_KEY=re_...
# REQUIRED on Vercel Production (and redeploy): a sender on your verified Resend domain.
# The app also reads RESEND_FROM, EMAIL_FROM, MAIL_FROM, NEXT_PUBLIC_RESEND_FROM_EMAIL if RESEND_FROM_EMAIL is unset.
# Do not wrap the value in extra quotes in the Vercel UI. Example: Proveit <noreply@yourdomain.com>
RESEND_FROM_EMAIL=Proveit <noreply@yourdomain.com>
#
# --- If email stopped working (checklist) ---
# 1) Vercel → Project → Settings → Environment Variables: confirm Production has
#    RESEND_API_KEY, RESEND_FROM_EMAIL (verified domain), SUPABASE_SERVICE_ROLE_KEY,
#    NEXT_PUBLIC_SUPABASE_URL. Save, then Deployments → … → Redeploy.
# 2) Resend dashboard → Logs: see API errors (domain, invalid key, blocked sender).
# 3) Supabase → Authentication → URL configuration: add https://YOUR_DOMAIN/api/auth/callback
#    and your Site URL. If you rotated the service_role key, paste the new value in Vercel.
# 4) Browser Network tab on "Resend confirmation" or forgot password: 501 = missing env;
#    503 = missing RESEND_FROM_EMAIL on Production; 502 + "Resend:" = Resend rejected the send;
#    502 without Resend prefix on confirm = Supabase generateLink failed (key/project).

# === Stripe (optional – for paid plans) ===
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
